---
import Layout from "@/layouts/Layout.astro";
import SiteHeader from "@/components/SiteHeader.astro";
import HeroSection from "@/components/HeroSection.astro";
import CountersSection from "@/components/CountersSection.astro";
import AboutSection from "@/components/AboutSection.astro";
import ServicesSection from "@/components/ServicesSection.astro";
import CtaBannerSection from "@/components/CtaBannerSection.astro";
import TestimonialsSection from "@/components/TestimonialsSection.astro";
import FaqSection from "@/components/FaqSection.astro";
import ContactSection from "@/components/ContactSection.astro";
import SiteFooter from "@/components/SiteFooter.astro";
import InternalLinksBlock from "@/components/InternalLinksBlock.astro";
import { FAQS, LOCATIONS } from "@/data/site";

const locationLinks = LOCATIONS.map((loc) => ({
  href: `/location/${loc.slug}/`,
  label: `${loc.name}, ${loc.state}`,
  description: `Door & window installation, repair, and replacement in ${loc.name}.`,
}));

const blogLinks = [
  {
    href: "/new-commercial-doors-what-to-look-for-when-upgrading-your-business-entrance/",
    label: "New Commercial Doors: What to Look For",
    description: "A complete buyer's guide for upgrading your business entrance.",
  },
  {
    href: "/about-us/",
    label: "About Top Notch Doors & Windows",
    description: "10+ years, 1,000+ projects, 97% referral rate. Meet our team.",
  },
  {
    href: "/contact-us/",
    label: "Get a Free Estimate",
    description: "Have a question or need a quick repair? Reach out anytime.",
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: FAQS.map((f) => ({
    "@type": "Question",
    name: f.question,
    acceptedAnswer: { "@type": "Answer", text: f.answer },
  })),
};
---

<Layout
  title="Door Repair & Window Services in Florida & New York | Top Notch Doors & Windows"
  description="Expert sliding door, pocket door, barn door, screen door, and impact window repair, installation, and replacement across Florida and New York. Free estimates. Call (954) 932-0764."
  schema={faqSchema}
>
  <SiteHeader />
  <main class="flex-1">
    <HeroSection />
    <CountersSection />
    <AboutSection />
    <ServicesSection />
    <InternalLinksBlock
      kicker="Service Areas"
      heading="Door & Window Service Across Florida & New York"
      intro="We proudly serve homeowners and businesses across multiple cities. Choose your location for area-specific service info."
      links={locationLinks}
      columns={4}
    />

    <CtaBannerSection />
    <TestimonialsSection />

    <InternalLinksBlock
      kicker="Learn More"
      heading="Explore Our Resources"
      intro="From expert tips to company background, get to know Top Notch Doors & Windows before you book."
      links={blogLinks}
      columns={3}
      variant="dark"
    />

    <FaqSection />
    <ContactSection />
  </main>
  <SiteFooter />
</Layout>
