---
import Layout from "@/layouts/Layout.astro";
import SiteHeader from "@/components/SiteHeader.astro";
import InnerHero from "@/components/InnerHero.astro";
import ContactSection from "@/components/ContactSection.astro";
import FaqSection from "@/components/FaqSection.astro";
import SiteFooter from "@/components/SiteFooter.astro";
import InternalLinksBlock from "@/components/InternalLinksBlock.astro";
import { LOCATIONS, SERVICE_CATEGORIES } from "@/data/site";

const locationLinks = LOCATIONS.map((loc) => ({
  href: `/location/${loc.slug}/`,
  label: `${loc.name}, ${loc.state}`,
  description: `Free estimates and fast service in ${loc.name}.`,
}));

const popularServices = SERVICE_CATEGORIES.flatMap((c) => c.services).slice(0, 6).map((s) => ({
  href: s.href,
  label: s.title,
  description: `Professional ${s.title.toLowerCase()} in Florida and New York.`,
}));
---

<Layout
  title="Contact Us — Top Notch Doors & Windows | Free Estimates"
  description="Get in touch with Top Notch Doors & Windows for fast, friendly door and window service across Florida and New York. Call (954) 932-0764 or request a free estimate online."
>
  <SiteHeader />
  <main class="flex-1">
    <InnerHero title="Contact Us" kicker="Get In Touch" />
    <ContactSection />

    <InternalLinksBlock
      kicker="Popular Services"
      heading="What We Can Help With"
      intro="Browse our most-requested door and window services."
      links={popularServices}
      columns={3}
    />

    <InternalLinksBlock
      kicker="Service Areas"
      heading="Find Service In Your City"
      links={locationLinks}
      columns={4}
      variant="dark"
    />

    <FaqSection />
  </main>
  <SiteFooter />
</Layout>
