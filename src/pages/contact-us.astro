---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import ContactForm from '../components/ContactForm.astro';
---

<Layout
  title="Contact Us | Top Notch Doors & Windows Fort Lauderdale"
  description="Contact Top Notch Doors & Windows for a free sliding door repair or window installation estimate in Fort Lauderdale. Call (954) 932-0764 today."
>
  <Hero
    headline="Contact Top Notch Doors & Windows"
    subtitle="Get a free estimate for sliding door repair and window services"
  />

  <section class="py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <p class="text-gray-600 text-lg leading-relaxed mb-6">
        Have a question? Need a quick sliding door repair? Want a free estimate for <a href="/" class="text-primary hover:underline">window installation or replacement</a>? We're here to help with all your door and window needs in Fort Lauderdale and across Florida — fast, friendly, and reliable service is just a call or message away.
      </p>
      <div class="flex flex-col sm:flex-row gap-6 justify-center items-center mb-8">
        <a href="tel:9549320764" class="flex items-center gap-2 text-primary font-heading text-2xl tracking-wide hover:underline" aria-label="Call Top Notch Doors & Windows">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
          (954) 932-0764
        </a>
        <span class="text-gray-400">|</span>
        <p class="text-gray-500">Servicing Fort Lauderdale, Miami, Palm Beach & New York</p>
      </div>
    </div>
  </section>

  <ContactForm heading="Get a Free Sliding Door & Window Estimate" />
</Layout>
