---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';
import ServiceFilter from '../../components/ServiceFilter.astro';
import FAQ from '../../components/FAQ.astro';
import ContactForm from '../../components/ContactForm.astro';
import CTABanner from '../../components/CTABanner.astro';
import locations from '../../data/locations.json';
import services from '../../data/services.json';

export function getStaticPaths() {
  return locations.map((loc) => ({
    params: { slug: loc.slug },
    props: { location: loc },
  }));
}

const { location } = Astro.props;
const pageTitle = `Door & Window Services ${location.name}, ${location.state} | Top Notch Doors & Windows`;
const metaDescription = `Expert sliding door repair, window installation & replacement in ${location.name}, ${location.state}. Free estimates. Call ${location.phone}. Top Notch Doors & Windows.`;
---

<Layout title={pageTitle} description={metaDescription}>
  <Hero
    headline={`Sliding Door & Window Services in ${location.name}, ${location.state}`}
    subtitle={`Trusted Door & Window Experts Serving ${location.name}`}
    showCtas={true}
  />

  <!-- Location Info -->
  <section class="py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="font-heading text-3xl md:text-4xl tracking-wide mb-6">Why Choose Top Notch in {location.name}?</h2>
        <p class="text-gray-600 text-lg leading-relaxed">{location.description}</p>
      </div>

      <!-- Highlights -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-12">
        {location.highlights.map((highlight: string) => (
          <div class="flex items-start gap-3 p-4 bg-gray-light rounded-lg">
            <svg class="w-6 h-6 text-primary flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            <span class="text-gray-700">{highlight}</span>
          </div>
        ))}
      </div>

      <!-- Areas Served -->
      <div class="bg-gray-light rounded-lg p-8 text-center">
        <h3 class="font-heading text-2xl tracking-wide mb-4">Areas We Serve Near {location.name}</h3>
        <div class="flex flex-wrap justify-center gap-3">
          {location.areas.map((area: string) => (
            <span class="bg-white px-4 py-2 rounded-full text-sm text-gray-600 border border-gray-border/30">{area}</span>
          ))}
        </div>
      </div>
    </div>
  </section>

  <ServiceFilter />

  <CTABanner heading={`Get a Free Estimate in ${location.name} Today`} />

  <FAQ />

  <ContactForm heading={`Request a Free Estimate in ${location.name}`} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": "Top Notch Doors & Windows",
    "description": `Door and window repair, installation and replacement services in ${location.name}, ${location.state}.`,
    "url": `https://topnotchdoorsandwindows.com/locations/${location.slug}`,
    "telephone": "+1-954-932-0764",
    "image": "https://topnotchdoorsandwindows.com/images/logo.png",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": location.name,
      "addressRegion": location.state,
      "addressCountry": "US"
    },
    "areaServed": location.areas.map((area: string) => ({ "@type": "City", "name": area }))
  })} />
</Layout>
