---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';
import ContactForm from '../../components/ContactForm.astro';
import servicePages from '../../data/service-pages.json';
import allServices from '../../data/services.json';

export function getStaticPaths() {
  return servicePages.map((service) => ({
    params: { slug: service.slug },
    props: { service },
  }));
}

const { service } = Astro.props;
const relatedServices = allServices.filter(s => s.slug !== service.slug).slice(0, 6);
---

<Layout title={service.title} description={service.metaDescription}>
  <Hero
    headline={service.name}
    subtitle="Fast, Reliable, Affordable"
    showCtas={true}
  />

  <!-- Service Overview -->
  <section class="py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-10 items-center">
        <div>
          <p class="text-gray-600 text-lg leading-relaxed">{service.overview}</p>
        </div>
        <div>
          <img src={service.image} alt={service.name} class="rounded-lg shadow-lg w-full" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- Benefits -->
  <section class="py-16 bg-gray-light">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="font-heading text-3xl md:text-4xl tracking-wide text-center mb-10">Benefits of {service.name}</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {service.benefits.map((benefit: string) => (
          <div class="flex items-start gap-3 p-4 bg-white rounded-lg shadow-sm">
            <svg class="w-6 h-6 text-primary flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            <span class="text-gray-700">{benefit}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Why Choose Us -->
  <section class="py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="font-heading text-3xl md:text-4xl tracking-wide text-center mb-10">Why Choose Top Notch Doors & Windows?</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {service.whyChoose.map((reason: string) => (
          <div class="text-center p-6 bg-gray-light rounded-lg">
            <svg class="w-10 h-10 text-primary mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
            <p class="text-gray-700">{reason}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-12 bg-primary text-white text-center">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="font-heading text-3xl md:text-4xl tracking-wide mb-6">{service.ctaHeading}</h2>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="tel:9549320764" class="inline-flex items-center justify-center gap-2 bg-white text-primary font-heading text-lg tracking-wide px-8 py-4 rounded hover:bg-gray-100 transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
          (954) 932-0764
        </a>
        <a href="/contact-us" class="inline-flex items-center justify-center bg-black text-white font-heading text-lg tracking-wide px-8 py-4 rounded hover:bg-gray-800 transition-colors">
          FREE ESTIMATE
        </a>
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="font-heading text-3xl md:text-4xl tracking-wide text-center mb-10">Our {service.name} Process</h2>
      <div class="space-y-4">
        {service.process.map((step: string, i: number) => (
          <div class="flex items-start gap-4 p-5 bg-gray-light rounded-lg">
            <div class="w-10 h-10 bg-primary text-white rounded-full flex items-center justify-center flex-shrink-0 font-heading text-lg">
              {i + 1}
            </div>
            <p class="text-gray-700 text-lg pt-1">{step}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Related Services -->
  <section class="py-16 bg-gray-light">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="font-heading text-3xl md:text-4xl tracking-wide text-center mb-10">Explore More Services by Top Notch Doors & Windows</h2>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4">
        {relatedServices.map((s) => (
          <a href={`/service/${s.slug}`} class="group block bg-white rounded-lg overflow-hidden shadow-sm hover:shadow-md transition-shadow border border-gray-border/30">
            <div class="aspect-square overflow-hidden">
              <img src={s.image} alt={s.name} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" />
            </div>
            <div class="p-3 text-center">
              <p class="font-heading text-sm tracking-wide text-primary group-hover:text-black transition-colors">{s.name}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQs -->
  <section class="py-16 bg-white">
    <div class="max-w-3xl mx-auto px-4">
      <h2 class="font-heading text-3xl md:text-4xl tracking-wide text-center mb-10">Frequently Asked Questions</h2>
      <div class="space-y-3" id="service-faq-list">
        {service.faqs.map((faq: {question: string; answer: string}) => (
          <div class="faq-item bg-gray-light rounded-lg overflow-hidden">
            <button class="service-faq-btn w-full flex justify-between items-center p-5 text-left" aria-expanded="false">
              <span class="font-medium text-primary pr-4">{faq.question}</span>
              <svg class="service-faq-icon w-5 h-5 flex-shrink-0 text-gray-400 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
            <div class="service-faq-answer hidden px-5 pb-5">
              <p class="text-gray-600 leading-relaxed">{faq.answer}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <ContactForm heading="Get a free estimate" />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Service",
    "name": service.name,
    "description": service.overview,
    "url": `https://topnotchdoorsandwindows.com/service/${service.slug}`,
    "provider": {
      "@type": "LocalBusiness",
      "name": "Top Notch Doors & Windows",
      "telephone": "+1-954-932-0764",
      "url": "https://topnotchdoorsandwindows.com"
    },
    "areaServed": [
      { "@type": "State", "name": "Florida" },
      { "@type": "State", "name": "New York" }
    ]
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": service.faqs.map((faq: {question: string; answer: string}) => ({
      "@type": "Question",
      "name": faq.question,
      "acceptedAnswer": { "@type": "Answer", "text": faq.answer }
    }))
  })} />
</Layout>

<script>
  document.querySelectorAll('.service-faq-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const answer = btn.nextElementSibling;
      const icon = btn.querySelector('.service-faq-icon');
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!expanded));
      answer?.classList.toggle('hidden');
      icon?.classList.toggle('rotate-180');
    });
  });
</script>
