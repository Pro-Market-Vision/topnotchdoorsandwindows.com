---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Stats from '../components/Stats.astro';
import ServiceFilter from '../components/ServiceFilter.astro';
import FAQ from '../components/FAQ.astro';
import ContactForm from '../components/ContactForm.astro';
---

<Layout title="About Us | Top Notch Doors & Windows">
  <Hero
    headline="Your Trusted Experts in Sliding Doors & Windows"
    subtitle="Welcome to Top Notch Doors & Windows"
  />

  <!-- About Content -->
  <section class="py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <p class="text-gray-600 text-lg leading-relaxed mb-8">
        Welcome to Top Notch Doors & Windows — where quality craftsmanship meets dependable service. We're proud to be a local leader in sliding door and window solutions, bringing years of hands-on experience and a passion for excellence to every job we do.
      </p>
    </div>
  </section>

  <Stats />

  <!-- Why Choose Us -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="font-heading text-4xl md:text-5xl text-center mb-10 tracking-wide">Why Choose Us</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="text-center p-6 bg-gray-light rounded-lg">
          <div class="w-14 h-14 bg-primary rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          </div>
          <h3 class="font-heading text-xl tracking-wide mb-2">Affordable, Transparent Pricing</h3>
          <p class="text-gray-600 text-sm">Complimentary, no-obligation estimates without hidden charges.</p>
        </div>
        <div class="text-center p-6 bg-gray-light rounded-lg">
          <div class="w-14 h-14 bg-primary rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" /></svg>
          </div>
          <h3 class="font-heading text-xl tracking-wide mb-2">Skilled & Friendly Technicians</h3>
          <p class="text-gray-600 text-sm">Experienced team trained to treat your property with care and respect.</p>
        </div>
        <div class="text-center p-6 bg-gray-light rounded-lg">
          <div class="w-14 h-14 bg-primary rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
          </div>
          <h3 class="font-heading text-xl tracking-wide mb-2">Warranty-Backed Workmanship</h3>
          <p class="text-gray-600 text-sm">All services include solid warranties for your confidence.</p>
        </div>
        <div class="text-center p-6 bg-gray-light rounded-lg">
          <div class="w-14 h-14 bg-primary rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
          </div>
          <h3 class="font-heading text-xl tracking-wide mb-2">Fast Response, Local Support</h3>
          <p class="text-gray-600 text-sm">Based in Florida with quick community response times.</p>
        </div>
      </div>
    </div>
  </section>

  <ServiceFilter />

  <FAQ />

  <ContactForm />
</Layout>
