---
import Layout from "@/layouts/Layout.astro";
import SiteHeader from "@/components/SiteHeader.astro";
import SiteFooter from "@/components/SiteFooter.astro";
import PrimaryButton from "@/components/PrimaryButton.astro";
import Icon from "@/components/Icon.astro";
import { PHONE_DISPLAY, PHONE_TEL } from "@/data/site";
---

<Layout
  title="Thank You — Top Notch Doors & Windows"
  description="Thanks for reaching out! We'll be in touch shortly."
  noindex={true}
>
  <SiteHeader />
  <main class="flex-1 bg-white">
    <section class="mx-auto max-w-[800px] px-5 lg:px-12 py-24 lg:py-32 text-center">
      <div class="inline-flex h-20 w-20 items-center justify-center rounded-full bg-[#004AAD] text-white mb-6">
        <svg viewBox="0 0 24 24" class="h-10 w-10" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M20 6L9 17l-5-5" />
        </svg>
      </div>
      <h1 class="font-[Bebas_Neue] text-[48px] sm:text-[64px] leading-[1.05] uppercase text-[#1D1D1D] font-medium">
        Thank You!
      </h1>
      <p class="mt-6 max-w-[550px] mx-auto font-[Roboto] text-[18px] leading-[30px] text-[#4D4D4D]">
        We received your message and will get back to you shortly. If you need immediate assistance, give us a call.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <PrimaryButton href={`tel:${PHONE_TEL}`} variant="solid">
          <Icon name="phone" class="h-4 w-4" />
          {PHONE_DISPLAY}
        </PrimaryButton>
        <PrimaryButton href="/">Back to Home</PrimaryButton>
      </div>
    </section>
  </main>
  <SiteFooter />
</Layout>
