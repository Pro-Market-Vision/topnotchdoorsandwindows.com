---
const services = {
  "Sliding Doors": [
    { name: "Sliding Door Repair", href: "/contact-us" },
    { name: "Sliding Door Replacement", href: "/contact-us" },
    { name: "Sliding Door Installation", href: "/contact-us" },
  ],
  "Glass & Window Services": [
    { name: "Glass Repair & Cutting", href: "/contact-us" },
    { name: "Impact Window Installation", href: "/contact-us" },
    { name: "Impact Window Replacement", href: "/contact-us" },
    { name: "Impact Window Repair", href: "/contact-us" },
  ],
  "Pocket Doors": [
    { name: "Pocket Door Repair", href: "/contact-us" },
    { name: "Pocket Door Installation", href: "/contact-us" },
  ],
  "Screen Doors": [
    { name: "Screen Door Installation", href: "/contact-us" },
    { name: "Screen Door Repair", href: "/contact-us" },
  ],
  "Commercial Services": [
    { name: "Commercial Door Services", href: "/contact-us" },
  ],
  "Barn Doors": [
    { name: "Barn Door Installation", href: "/contact-us" },
    { name: "Barn Door Repair", href: "/contact-us" },
  ],
};

const locations = [
  { name: "Fort Lauderdale, FL", href: "/locations/fort-lauderdale" },
  { name: "Miami, FL", href: "/locations/miami" },
  { name: "Palm Beach, FL", href: "/locations/palm-beach" },
  { name: "Weston, FL", href: "/locations/weston" },
  { name: "New York, NY", href: "/locations/new-york" },
];
---

<!-- Top Bar -->
<div class="bg-primary text-white text-sm py-2">
  <div class="max-w-7xl mx-auto px-4 flex justify-end items-center gap-4">
    <span>Serving Fort Lauderdale, Miami, Palm Beach & New York</span>
    <a href="tel:9549320764" class="hover:underline font-semibold" aria-label="Call Top Notch Doors & Windows">(954) 932-0764</a>
  </div>
</div>

<!-- Main Navigation -->
<header class="bg-white shadow-sm sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-4 flex items-center justify-between h-24">
    <!-- Logo -->
    <a href="/" class="flex-shrink-0">
      <img src="/images/logo.png" alt="Top Notch Doors & Windows - Sliding Door Repair Fort Lauderdale" class="h-20 w-auto" />
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden lg:flex items-center gap-8" aria-label="Main navigation">
      <!-- Services Dropdown -->
      <div class="relative group">
        <button class="font-heading text-lg tracking-wide text-primary hover:text-black flex items-center gap-1 py-2" aria-label="View our door and window services">
          SERVICES
          <svg class="w-4 h-4 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
        </button>
        <div class="absolute top-full left-1/2 -translate-x-1/2 pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
          <div class="bg-white shadow-xl rounded-lg p-6 grid grid-cols-3 gap-6 min-w-[600px] border border-gray-100">
            {Object.entries(services).map(([category, items]) => (
              <div>
                <h4 class="font-heading text-sm tracking-wide text-primary mb-2 border-b border-gray-200 pb-1">{category}</h4>
                <ul class="space-y-1">
                  {items.map((item) => (
                    <li><a href={item.href} class="text-sm text-gray-600 hover:text-primary transition-colors">{item.name}</a></li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- Locations Dropdown -->
      <div class="relative group">
        <button class="font-heading text-lg tracking-wide text-primary hover:text-black flex items-center gap-1 py-2" aria-label="View service locations">
          LOCATIONS
          <svg class="w-4 h-4 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
        </button>
        <div class="absolute top-full left-0 pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
          <div class="bg-white shadow-xl rounded-lg py-2 min-w-[200px] border border-gray-100">
            {locations.map((loc) => (
              <a href={loc.href} class="block px-4 py-2 text-sm text-gray-600 hover:bg-gray-50 hover:text-primary transition-colors">{loc.name}</a>
            ))}
          </div>
        </div>
      </div>

      <a href="/about-us" class="font-heading text-lg tracking-wide text-primary hover:text-black py-2">ABOUT US</a>
      <a href="/contact-us" class="font-heading text-lg tracking-wide text-primary hover:text-black py-2">CONTACT US</a>
      <a href="/blog" class="font-heading text-lg tracking-wide text-primary hover:text-black py-2">BLOG</a>
    </nav>

    <!-- CTA Button (Desktop) -->
    <a href="tel:9549320764" class="hidden lg:inline-flex bg-primary text-white font-heading text-lg tracking-wide px-6 py-3 rounded hover:bg-black transition-colors" aria-label="Call now for a free estimate">
      CALL NOW
    </a>

    <!-- Mobile Menu Button -->
    <button id="mobile-menu-btn" class="lg:hidden p-2" aria-label="Open navigation menu">
      <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" /></svg>
    </button>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden lg:hidden bg-white border-t border-gray-100">
    <div class="px-4 py-4 space-y-3">
      <div>
        <button class="mobile-dropdown-btn w-full flex justify-between items-center font-heading text-lg tracking-wide text-primary py-2">
          SERVICES
          <svg class="w-4 h-4 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
        </button>
        <div class="mobile-dropdown hidden pl-4 space-y-2 pb-2">
          {Object.entries(services).map(([category, items]) => (
            <div class="py-1">
              <p class="text-xs font-bold text-gray-400 uppercase tracking-wider">{category}</p>
              {items.map((item) => (
                <a href={item.href} class="block text-sm text-gray-600 py-1">{item.name}</a>
              ))}
            </div>
          ))}
        </div>
      </div>
      <div>
        <button class="mobile-dropdown-btn w-full flex justify-between items-center font-heading text-lg tracking-wide text-primary py-2">
          LOCATIONS
          <svg class="w-4 h-4 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
        </button>
        <div class="mobile-dropdown hidden pl-4 space-y-1 pb-2">
          {locations.map((loc) => (
            <a href={loc.href} class="block text-sm text-gray-600 py-1">{loc.name}</a>
          ))}
        </div>
      </div>
      <a href="/about-us" class="block font-heading text-lg tracking-wide text-primary py-2">ABOUT US</a>
      <a href="/contact-us" class="block font-heading text-lg tracking-wide text-primary py-2">CONTACT US</a>
      <a href="/blog" class="block font-heading text-lg tracking-wide text-primary py-2">BLOG</a>
      <a href="tel:9549320764" class="block bg-primary text-white font-heading text-lg tracking-wide px-6 py-3 rounded text-center mt-4">CALL NOW</a>
    </div>
  </div>
</header>

<script>
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  menuBtn?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });

  document.querySelectorAll('.mobile-dropdown-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const dropdown = btn.nextElementSibling;
      const icon = btn.querySelector('svg');
      dropdown?.classList.toggle('hidden');
      icon?.classList.toggle('rotate-180');
    });
  });
</script>
