---
// Tiny icon set extracted from the original site, rendered inline as SVG.
// Usage: <Icon name="phone" class="h-4 w-4" />
interface Props {
  name: "phone" | "map-pin" | "chevron-down" | "plus" | "minus" | "arrow-right" | "menu" | "facebook" | "instagram";
  class?: string;
}
const { name, class: className = "" } = Astro.props;
---

{name === "phone" && (
  <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" class={className}>
    <path d="M6.62 10.79a15.05 15.05 0 0 0 6.59 6.59l2.2-2.2a1 1 0 0 1 1.05-.24c1.16.39 2.4.6 3.66.6a1 1 0 0 1 1 1V20a1 1 0 0 1-1 1A17 17 0 0 1 3 4a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1c0 1.26.21 2.5.6 3.66a1 1 0 0 1-.24 1.05l-2.24 2.08Z" />
  </svg>
)}
{name === "map-pin" && (
  <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" class={className}>
    <path d="M12 2a8 8 0 0 0-8 8c0 5.4 7.05 11.55 7.35 11.81a1 1 0 0 0 1.3 0C12.95 21.55 20 15.4 20 10a8 8 0 0 0-8-8Zm0 11a3 3 0 1 1 0-6 3 3 0 0 1 0 6Z" />
  </svg>
)}
{name === "chevron-down" && (
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class={className}>
    <path d="m6 9 6 6 6-6" />
  </svg>
)}
{name === "plus" && (
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class={className}>
    <path d="M12 5v14M5 12h14" />
  </svg>
)}
{name === "minus" && (
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class={className}>
    <path d="M5 12h14" />
  </svg>
)}
{name === "arrow-right" && (
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class={className}>
    <path d="M5 12h14M13 5l7 7-7 7" />
  </svg>
)}
{name === "menu" && (
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true" class={className}>
    <path d="M3 6h18M3 12h18M3 18h18" />
  </svg>
)}
{name === "facebook" && (
  <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" class={className}>
    <path d="M22 12a10 10 0 1 0-11.56 9.88v-6.99H7.9V12h2.54V9.8c0-2.5 1.49-3.89 3.78-3.89 1.09 0 2.24.2 2.24.2v2.46h-1.26c-1.24 0-1.63.77-1.63 1.56V12h2.78l-.44 2.89h-2.34v6.99A10 10 0 0 0 22 12Z" />
  </svg>
)}
{name === "instagram" && (
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class={className}>
    <rect x="3" y="3" width="18" height="18" rx="5" />
    <circle cx="12" cy="12" r="4" />
    <circle cx="17.5" cy="6.5" r="0.6" fill="currentColor" />
  </svg>
)}
