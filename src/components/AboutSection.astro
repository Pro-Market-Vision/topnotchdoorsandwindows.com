---
import PrimaryButton from "./PrimaryButton.astro";
---

<section id="about" class="bg-white">
  <div class="mx-auto max-w-[1240px] px-5 lg:px-12 py-20 lg:py-24 grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16 items-center">
    <div class="lg:col-span-5 border-l-4 border-[#004AAD] pl-4">
      <img src="/images/about.jpg" alt="Top Notch Doors & Windows installation" width="952" height="1024" class="w-full h-auto" />
    </div>
    <div class="lg:col-span-7">
      <div class="font-[Bebas_Neue] text-[20px] uppercase text-[#101010] tracking-wider">About Us</div>
      <div class="mt-2 mb-6 h-[3px] w-12 bg-[#004AAD]" aria-hidden="true"></div>
      <h2 class="font-[Bebas_Neue] text-[36px] sm:text-[44px] lg:text-[48px] leading-[1.05] uppercase text-[#1D1D1D] font-medium">
        Discover Unmatched Door Solutions at Top Notch Doors & Windows
      </h2>
      <p class="mt-6 text-[16px] leading-[28px] text-[#7A7A7A]">
        At Top Notch Doors & Windows, we are dedicated to providing affordable, high-quality service for all your door and window needs. Whether it's <a href="/service/sliding-door-installation/" class="text-[#004AAD] font-semibold hover:underline">sliding door installation</a>, <a href="/service/pocket-door-repair/" class="text-[#004AAD] font-semibold hover:underline">pocket door repair</a>, or <a href="/service/impact-window-installation/" class="text-[#004AAD] font-semibold hover:underline">impact window installation</a>, our team ensures every project is completed with the highest standards of craftsmanship and customer care. We offer warranties and free estimates for every service we provide. Simply give us a call at <a href="tel:+19549320764" class="text-[#004AAD] font-semibold hover:underline">(954) 932-0764</a> to get started!
      </p>
      <div class="mt-8 flex flex-wrap gap-4">
        <PrimaryButton href="/about-us/">About Us</PrimaryButton>
        <PrimaryButton href="#contact">Free Estimate</PrimaryButton>
      </div>
    </div>
  </div>
</section>
