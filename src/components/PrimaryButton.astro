---
interface Props {
  variant?: "solid" | "outline-white" | "solid-white";
  href?: string;
  class?: string;
}
const { variant = "solid", href, class: className = "" } = Astro.props;

const base =
  "inline-flex items-center justify-center gap-2 px-[30px] py-[15px] font-semibold text-[16px] leading-[26px] transition-colors duration-200 rounded-full border-2 cursor-pointer";

const variantClasses: Record<string, string> = {
  solid: "bg-[#004AAD] text-white border-[#004AAD] hover:bg-[#003a87] hover:border-[#003a87]",
  "outline-white": "bg-transparent text-white border-white hover:bg-white hover:text-[#004AAD]",
  "solid-white": "bg-white text-[#004AAD] border-white hover:bg-[#004AAD] hover:text-white",
};

const classes = `${base} ${variantClasses[variant]} ${className}`;
---

{href ? (
  <a href={href} class={classes}>
    <slot />
  </a>
) : (
  <button type="button" class={classes}>
    <slot />
  </button>
)}
