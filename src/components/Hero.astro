---
interface Props {
  headline: string;
  subtitle?: string;
  description?: string;
  showCtas?: boolean;
  showStats?: boolean;
}

const { headline, subtitle, description, showCtas = false, showStats = false } = Astro.props;
---

<section class="relative bg-primary text-white py-24 md:py-32 overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-r from-primary/95 to-primary/80"></div>
  <div class="relative max-w-7xl mx-auto px-4 text-center">
    <h1 class="font-heading text-5xl md:text-7xl tracking-wide mb-4">{headline}</h1>
    {subtitle && <p class="text-xl md:text-2xl font-light mb-4 text-gray-200">{subtitle}</p>}
    {description && <p class="text-base md:text-lg max-w-2xl mx-auto text-gray-300 mb-8">{description}</p>}

    {showCtas && (
      <div class="flex flex-col sm:flex-row gap-4 justify-center mb-12">
        <a href="tel:9549320764" class="bg-white text-primary font-heading text-xl tracking-wide px-8 py-4 rounded hover:bg-gray-100 transition-colors">
          (954) 932-0764
        </a>
        <a href="/contact-us" class="border-2 border-white text-white font-heading text-xl tracking-wide px-8 py-4 rounded hover:bg-white hover:text-primary transition-colors">
          FREE ESTIMATE
        </a>
      </div>
    )}

    {showStats && (
      <div class="grid grid-cols-3 gap-8 max-w-2xl mx-auto mt-8">
        <div>
          <p class="font-heading text-4xl md:text-5xl">1,000+</p>
          <p class="text-sm text-gray-300 mt-1">Projects Completed</p>
        </div>
        <div>
          <p class="font-heading text-4xl md:text-5xl">97%</p>
          <p class="text-sm text-gray-300 mt-1">Referral Rate</p>
        </div>
        <div>
          <p class="font-heading text-4xl md:text-5xl">10+</p>
          <p class="text-sm text-gray-300 mt-1">Years Delivering Quality</p>
        </div>
      </div>
    )}
  </div>
</section>
