---
interface Props {
  name: string;
  image: string;
  category: string;
}

const { name, image, category } = Astro.props;
---

<div class="service-card group bg-white rounded-lg overflow-hidden shadow-md hover:shadow-2xl hover:-translate-y-2 transition-all duration-300 border border-gray-border/30" data-category={category}>
  <div class="aspect-[4/3] overflow-hidden">
    <img src={image} alt={name} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" />
  </div>
  <div class="p-4">
    <h3 class="font-heading text-xl tracking-wide text-primary">{name}</h3>
    <span class="text-xs text-gray-400 uppercase tracking-wider">{category}</span>
    <div class="mt-3">
      <span class="inline-flex items-center gap-1 text-primary font-heading text-sm tracking-wide group-hover:gap-2 transition-all duration-300">
        LEARN MORE
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
      </span>
    </div>
  </div>
</div>
