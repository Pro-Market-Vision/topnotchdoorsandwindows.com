---
interface Props {
  name: string;
  image: string;
  category: string;
}

const { name, image, category } = Astro.props;
---

<div class="service-card group bg-white rounded-lg overflow-hidden shadow-md hover:shadow-xl hover:-translate-y-1 transition-all duration-300 border border-gray-border/30" data-category={category}>
  <div class="aspect-[4/3] overflow-hidden">
    <img src={image} alt={name} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" />
  </div>
  <div class="p-4">
    <h3 class="font-heading text-xl tracking-wide text-primary">{name}</h3>
    <span class="text-xs text-gray-400 uppercase tracking-wider">{category}</span>
  </div>
</div>
