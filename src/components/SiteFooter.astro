---
import Icon from "./Icon.astro";
import { COMPANY, PHONE_DISPLAY, PHONE_TEL, SERVICE_CATEGORIES, LOCATIONS } from "@/data/site";

const QUICK_LINKS = [
  { label: "Home", href: "/" },
  { label: "About Us", href: "/about-us/" },
  { label: "Contact Us", href: "/contact-us/" },
  { label: "Blog", href: "/blog/" },
  { label: "Free Estimate", href: "/contact-us/#contact" },
];
---

<footer class="bg-[#0F1117] text-white border-t-4 border-[#004AAD]">
  <div class="mx-auto max-w-[1240px] px-5 lg:px-12 pt-20 pb-12">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
      {/* Brand column */}
      <div class="lg:col-span-4">
        <div class="bg-white inline-block p-3">
          <img src="/images/logo.png" alt={COMPANY} width="300" height="100" class="h-14 w-auto" />
        </div>
        <p class="mt-6 font-[Roboto] text-[14px] leading-[26px] text-white/70">
          Proudly serving Florida & New York with expert door and window solutions you can rely on. Quality craftsmanship, honest pricing, and service that's truly Top Notch.
        </p>
        <div class="mt-6 space-y-3">
          <a href={`tel:${PHONE_TEL}`} class="flex items-center justify-center gap-2 bg-[#004AAD] text-white py-3 px-5 font-[Bebas_Neue] text-[18px] tracking-[0.12em] rounded-full border-2 border-[#004AAD] hover:bg-transparent transition-colors w-full">
            <Icon name="phone" class="h-4 w-4" />
            {PHONE_DISPLAY}
          </a>
          <div class="flex items-center gap-3 bg-[#1A1D27] border border-white/10 rounded-lg px-4 py-3 text-[14px] text-white">
            <span class="flex h-9 w-9 shrink-0 items-center justify-center bg-[#004AAD] text-white rounded-md">
              <Icon name="map-pin" class="h-4 w-4" />
            </span>
            <span>Servicing Florida & New York</span>
          </div>
        </div>
      </div>

      {/* Services column */}
      <div class="lg:col-span-5">
        <div class="flex items-center gap-3 mb-6">
          <span class="block h-[8px] w-[8px] bg-[#004AAD]" aria-hidden="true"></span>
          <h3 class="font-[Bebas_Neue] text-[22px] uppercase tracking-wider text-white leading-none m-0">Our Services</h3>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-6">
          {SERVICE_CATEGORIES.map((cat) => (
            <div>
              <h4 class="font-[Bebas_Neue] text-[16px] uppercase text-[#7DB3FF] mb-3">{cat.label}</h4>
              <ul class="space-y-2">
                {cat.services.map((s) => (
                  <li>
                    <a href={s.href} class="font-[Roboto] text-[13px] text-white/70 hover:text-white transition-colors">
                      {s.title}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>

      {/* Locations + Quick Links column */}
      <div class="lg:col-span-3 space-y-8">
        <div>
          <div class="flex items-center gap-3 mb-6">
            <span class="block h-[8px] w-[8px] bg-[#004AAD]" aria-hidden="true"></span>
            <h3 class="font-[Bebas_Neue] text-[22px] uppercase tracking-wider text-white leading-none m-0">Locations</h3>
          </div>
          <ul class="space-y-2">
            {LOCATIONS.map((loc) => (
              <li>
                <a href={`/location/${loc.slug}/`} class="font-[Roboto] text-[14px] text-white/70 hover:text-white transition-colors">
                  {loc.name}, {loc.state}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <div>
          <div class="flex items-center gap-3 mb-6">
            <span class="block h-[8px] w-[8px] bg-[#004AAD]" aria-hidden="true"></span>
            <h3 class="font-[Bebas_Neue] text-[22px] uppercase tracking-wider text-white leading-none m-0">Quick Links</h3>
          </div>
          <ul class="space-y-2">
            {QUICK_LINKS.map((link) => (
              <li>
                <a href={link.href} class="font-[Roboto] text-[14px] text-white/70 hover:text-white transition-colors">
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </div>

  <div class="border-t border-white/10">
    <div class="mx-auto max-w-[1240px] px-5 lg:px-12 py-5 flex flex-col sm:flex-row items-center justify-between gap-3 text-[13px] text-white/60">
      <div>© {new Date().getFullYear()} {COMPANY}. All Rights Reserved.</div>
      <div class="flex items-center gap-3">
        <a href="/privacy-policy/" class="hover:text-white transition-colors">Privacy Policy</a>
        <span>·</span>
        <span>Florida & New York · Free Estimates</span>
      </div>
    </div>
  </div>
</footer>
