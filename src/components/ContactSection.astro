---
import Icon from "./Icon.astro";
import { PHONE_DISPLAY as DEFAULT_PHONE_DISPLAY, PHONE_TEL as DEFAULT_PHONE_TEL } from "@/data/site";

interface Props {
  phoneDisplay?: string;
  phoneTel?: string;
}

const { phoneDisplay = DEFAULT_PHONE_DISPLAY, phoneTel = DEFAULT_PHONE_TEL } = Astro.props;
const PHONE_DISPLAY = phoneDisplay;
const PHONE_TEL = phoneTel;

const inputClass =
  "w-full bg-white border border-[#E5E5E5] px-[18px] py-[14px] text-[16px] text-[#1D1D1D] placeholder:text-[#9a9a9a] focus:outline-none focus:border-[#004AAD] transition-colors";
---

<section id="contact" class="bg-white border-t-4 border-[#004AAD]">
  <div class="mx-auto max-w-[1240px] px-5 lg:px-12 py-20 lg:py-24 grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">
    <div class="lg:col-span-5">
      <div class="font-[Bebas_Neue] text-[20px] uppercase tracking-wider text-[#101010]">Contact Us</div>
      <div class="mt-2 mb-6 h-[3px] w-12 bg-[#004AAD]" aria-hidden="true"></div>
      <h2 class="font-[Bebas_Neue] text-[44px] sm:text-[52px] lg:text-[56px] leading-[1.08] uppercase font-medium text-[#1D1D1D]">
        Get a free estimate
      </h2>
      <p class="mt-6 text-[16px] leading-[28px] text-[#7A7A7A]">
        Have a question? Need a quick repair? Want a free estimate? We're here to help with all your door and window needs—fast, friendly, and reliable service is just a call or message away.
      </p>
      <div class="mt-8 space-y-4">
        <a
          href={`tel:${PHONE_TEL}`}
          class="flex w-full sm:w-auto sm:inline-flex items-center justify-center gap-3 bg-[#004AAD] text-white py-4 px-7 font-[Bebas_Neue] text-[20px] tracking-[0.1em] rounded-full border-2 border-[#004AAD] hover:bg-[#003a87] hover:border-[#003a87] transition-colors"
        >
          <Icon name="phone" class="h-5 w-5" />
          {PHONE_DISPLAY}
        </a>
        <div class="inline-flex items-center gap-3 bg-white border-2 border-[#004AAD] rounded-lg px-4 py-3 text-[16px] font-medium text-[#1D1D1D]">
          <span class="flex h-10 w-10 shrink-0 items-center justify-center bg-[#004AAD] text-white rounded-md">
            <Icon name="map-pin" class="h-4 w-4" />
          </span>
          Servicing Florida & New York
        </div>
      </div>
    </div>

    <div class="lg:col-span-7">
      <div class="bg-[#F5F5F5] p-8 sm:p-10 border-2 border-[#004AAD]">
        <form data-form-name="Contact Form - Top Notch Doors & Windows" class="space-y-5">
          <input type="hidden" name="access_key" value="9393b426-71fc-49e0-9346-eebb28bd6b72" />
          <input type="hidden" name="subject" value="New Lead - Top Notch Doors & Windows" />
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <input name="Name" required placeholder="Name *" autocomplete="name" class={inputClass} />
            <input name="Email" type="email" required placeholder="Email *" autocomplete="email" class={inputClass} />
          </div>
          <input
            name="Phone"
            type="tel"
            required
            inputmode="tel"
            placeholder="Phone *"
            autocomplete="tel"
            maxlength="12"
            class={inputClass}
          />
          <textarea name="Message" placeholder="Message" rows="6" class={inputClass}></textarea>
          <button
            type="submit"
            class="w-full bg-[#004AAD] text-white py-4 font-[Bebas_Neue] text-[18px] uppercase tracking-[0.18em] rounded-full border-2 border-[#004AAD] hover:bg-[#003a87] hover:border-[#003a87] transition-colors disabled:opacity-60"
          >
            Send
          </button>
        </form>
        <div data-form-success class="text-center py-16 hidden">
          <div class="font-[Bebas_Neue] text-[32px] uppercase text-[#1D1D1D]">Thanks!</div>
          <p class="mt-4 text-[16px] text-[#7A7A7A]">We'll be in touch shortly.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  // Phone auto-format: XXX-XXX-XXXX
  document.querySelectorAll('input[name="Phone"]').forEach((input) => {
    input.addEventListener("input", () => {
      const el = input as HTMLInputElement;
      const digits = el.value.replace(/\D/g, "").slice(0, 10);
      let formatted = digits;
      if (digits.length > 6) {
        formatted = `${digits.slice(0, 3)}-${digits.slice(3, 6)}-${digits.slice(6)}`;
      } else if (digits.length > 3) {
        formatted = `${digits.slice(0, 3)}-${digits.slice(3)}`;
      }
      el.value = formatted;
    });
  });
</script>
