---
const serviceLinks = {
  "Sliding Doors": [
    { name: "Sliding Door Repair", href: "/contact-us" },
    { name: "Sliding Door Replacement", href: "/contact-us" },
    { name: "Sliding Door Installation", href: "/contact-us" },
  ],
  "Pocket Doors": [
    { name: "Pocket Door Repair", href: "/contact-us" },
    { name: "Pocket Door Installation", href: "/contact-us" },
  ],
  "Commercial Services": [
    { name: "Commercial Door Services", href: "/contact-us" },
  ],
  "Glass & Window Services": [
    { name: "Glass Repair & Cutting", href: "/contact-us" },
    { name: "Impact Window Installation", href: "/contact-us" },
    { name: "Impact Window Replacement", href: "/contact-us" },
    { name: "Impact Window Repair", href: "/contact-us" },
  ],
  "Screen Doors": [
    { name: "Screen Door Installation", href: "/contact-us" },
    { name: "Screen Door Repair", href: "/contact-us" },
  ],
  "Barn Doors": [
    { name: "Barn Door Installation", href: "/contact-us" },
    { name: "Barn Door Repair", href: "/contact-us" },
  ],
};
const currentYear = new Date().getFullYear();
---

<footer class="bg-primary text-white">
  <div class="max-w-7xl mx-auto px-4 py-12">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      <!-- Brand Column -->
      <div>
        <a href="/" aria-label="Top Notch Doors & Windows homepage">
          <img src="/images/logo.png" alt="Top Notch Doors & Windows logo" class="h-16 w-auto mb-4 brightness-0 invert" />
        </a>
        <p class="text-gray-300 text-sm leading-relaxed">
          Proudly serving Fort Lauderdale, Miami, and South Florida with expert sliding door repair, window installation, and replacement services. Quality craftsmanship, honest pricing, and service that's truly Top Notch.
        </p>
        <div class="mt-4">
          <a href="tel:9549320764" class="text-white font-heading text-xl tracking-wide hover:underline" aria-label="Call Top Notch Doors & Windows">(954) 932-0764</a>
          <p class="text-gray-400 text-sm mt-1">Fort Lauderdale, FL | Servicing all of Florida & New York</p>
        </div>
      </div>

      <!-- Service Links -->
      {Object.entries(serviceLinks).slice(0, 2).map(([category, items]) => (
        <div>
          <h4 class="font-heading text-lg tracking-wide mb-3">{category}</h4>
          <ul class="space-y-2">
            {items.map((item) => (
              <li><a href={item.href} class="text-gray-300 text-sm hover:text-white transition-colors">{item.name}</a></li>
            ))}
          </ul>
        </div>
      ))}

      <!-- More Links -->
      <div>
        {Object.entries(serviceLinks).slice(2, 4).map(([category, items]) => (
          <div class="mb-4">
            <h4 class="font-heading text-lg tracking-wide mb-2">{category}</h4>
            <ul class="space-y-1">
              {items.map((item) => (
                <li><a href={item.href} class="text-gray-300 text-sm hover:text-white transition-colors">{item.name}</a></li>
              ))}
            </ul>
          </div>
        ))}
        <div class="mt-4">
          <h4 class="font-heading text-lg tracking-wide mb-2">Locations</h4>
          <ul class="space-y-1">
            <li><a href="/locations/fort-lauderdale" class="text-gray-300 text-sm hover:text-white transition-colors">Fort Lauderdale, FL</a></li>
            <li><a href="/locations/miami" class="text-gray-300 text-sm hover:text-white transition-colors">Miami, FL</a></li>
            <li><a href="/locations/palm-beach" class="text-gray-300 text-sm hover:text-white transition-colors">Palm Beach, FL</a></li>
            <li><a href="/locations/weston" class="text-gray-300 text-sm hover:text-white transition-colors">Weston, FL</a></li>
            <li><a href="/locations/new-york" class="text-gray-300 text-sm hover:text-white transition-colors">New York, NY</a></li>
          </ul>
        </div>
        <div class="mt-4 space-y-1">
          <a href="/about-us" class="block text-gray-300 text-sm hover:text-white transition-colors">About Us</a>
          <a href="/blog" class="block text-gray-300 text-sm hover:text-white transition-colors">Blog</a>
          <a href="/contact-us" class="block text-gray-300 text-sm hover:text-white transition-colors">Contact Us</a>
          <a href="/privacy-policy" class="block text-gray-300 text-sm hover:text-white transition-colors">Privacy Policy</a>
        </div>
      </div>
    </div>
  </div>

  <!-- Copyright -->
  <div class="border-t border-gray-600">
    <div class="max-w-7xl mx-auto px-4 py-4">
      <p class="text-gray-400 text-sm text-center">&copy; {currentYear} Top Notch Doors & Windows. All Rights Reserved.</p>
    </div>
  </div>
</footer>
