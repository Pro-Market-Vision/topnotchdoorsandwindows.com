---
import ServiceCard from './ServiceCard.astro';
import services from '../data/services.json';

const categories = ["All", ...new Set(services.map(s => s.category))];
---

<section class="py-16 bg-white">
  <div class="max-w-7xl mx-auto px-4">
    <h2 class="font-heading text-4xl md:text-5xl text-center mb-2 tracking-wide">Our Services</h2>
    <p class="text-gray-500 text-center mb-8">Expert door and window solutions for every need</p>

    <!-- Filter Tabs -->
    <div class="flex flex-wrap justify-center gap-2 mb-10" id="filter-tabs">
      {categories.map((cat) => (
        <button
          class="filter-btn px-4 py-2 text-sm font-medium rounded-full border border-gray-300 text-gray-600 hover:bg-primary hover:text-white hover:border-primary transition-colors data-[active]:bg-primary data-[active]:text-white data-[active]:border-primary"
          data-filter={cat}
          data-active={cat === "All" ? "" : undefined}
        >
          {cat}
        </button>
      ))}
    </div>

    <!-- Service Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6" id="services-grid">
      {services.map((service) => (
        <ServiceCard name={service.name} image={service.image} category={service.category} />
      ))}
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('.filter-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.filter-btn').forEach(b => b.removeAttribute('data-active'));
      btn.setAttribute('data-active', '');

      const filter = btn.getAttribute('data-filter');
      document.querySelectorAll('.service-card').forEach(card => {
        const category = card.getAttribute('data-category');
        if (filter === 'All' || category === filter) {
          (card as HTMLElement).style.display = '';
        } else {
          (card as HTMLElement).style.display = 'none';
        }
      });
    });
  });
</script>
