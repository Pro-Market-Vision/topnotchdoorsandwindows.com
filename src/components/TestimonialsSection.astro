---
import { TESTIMONIALS, type Testimonial } from "@/data/site";

interface Props {
  testimonials?: Testimonial[];
  locationName?: string;
}

const { testimonials = TESTIMONIALS, locationName } = Astro.props;
const heading = locationName
  ? `What ${locationName} Clients Say About Us`
  : "What Our Clients Say About Us";
const intro = locationName
  ? `From door repairs to full window installations, discover how we've helped homeowners and businesses in ${locationName} with reliable, top-notch solutions.`
  : "From door repairs to full window installations, our team delivers expert craftsmanship and friendly service every step of the way. Discover how we've helped homeowners and businesses throughout South Florida with reliable, top-notch solutions they can count on.";
---

<section class="bg-white border-t-4 border-[#004AAD]">
  <div class="mx-auto max-w-[1240px] px-5 lg:px-12 py-20 lg:py-24">
    <div class="text-center max-w-[900px] mx-auto">
      <div class="font-[Bebas_Neue] text-[20px] uppercase tracking-wider text-[#101010]">Testimonials</div>
      <div class="mx-auto mt-2 mb-6 h-[3px] w-12 bg-[#004AAD]" aria-hidden="true"></div>
      <h2 class="font-[Bebas_Neue] text-[40px] sm:text-[44px] lg:text-[48px] leading-[1.08] uppercase font-medium text-[#1D1D1D]">
        {heading}
      </h2>
      <p class="mt-6 text-[16px] leading-[28px] text-[#7A7A7A]">
        {intro}
      </p>
    </div>

    <div class="mt-16 grid grid-cols-1 md:grid-cols-3 gap-8">
      {testimonials.map((t) => (
        <figure class="bg-[#F5F5F5] p-8 flex flex-col border-t-4 border-[#004AAD]">
          <div class="flex gap-1 text-[#FFC107]" aria-label="5 out of 5 stars">
            {[0, 1, 2, 3, 4].map(() => (
              <svg viewBox="0 0 20 20" class="h-4 w-4 fill-current" aria-hidden="true">
                <path d="M10 1.5l2.6 5.27 5.82.85-4.21 4.1.99 5.78L10 14.77l-5.2 2.73.99-5.78L1.58 7.62l5.82-.85L10 1.5z" />
              </svg>
            ))}
          </div>
          <blockquote class="mt-4 italic text-[16px] leading-[28px] text-[#4D4D4D] flex-1">
            {t.quote}
          </blockquote>
          <div class="my-4 h-px w-full bg-[#E5E5E5]"></div>
          <figcaption>
            <div class="font-[Bebas_Neue] text-[20px] uppercase text-[#1D1D1D]">{t.name}</div>
            <div class="text-[14px] text-[#7A7A7A]">{t.location}</div>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>
